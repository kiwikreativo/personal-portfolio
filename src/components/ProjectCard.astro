---
const { imageSrc, imageAlt, tag, title, description, link } = Astro.props;
---

<div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0px_4px_20px_rgba(0,0,0,0.04)] hover:shadow-[0px_8px_30px_rgba(0,0,0,0.08)] transition-all duration-300 group">
  <div class="aspect-video overflow-hidden border-b border-outline-variant/30">
    <img
      alt={imageAlt}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
      src={imageSrc}
    />
  </div>
  <div class="p-8">
    <span class="font-label-caps text-label-caps text-primary bg-primary-container/20 px-2 py-1 rounded mb-4 inline-block">{tag}</span>
    <h3 class="font-h3 text-h3 text-on-surface mb-3">{title}</h3>
    <p class="font-body-md text-body-md text-on-surface-variant mb-6">{description}</p>
    <a href={link} target="_blank" class="mt-6 inline-block px-6 py-2 bg-primary text-white rounded-full w-35 font-medium hover:bg-primary-container transition-colors duration-300">Learn More</a>
  </div>
</div>
