<section class="py-[120px] bg-surface-container-low" id="contact">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="font-display text-display text-on-surface mb-6">Leave a Message</h2>
    <p class="font-body-lg text-body-lg text-on-surface-variant mb-12">I'm always open to discussing new projects, design ideas, or the future of tech.</p>
    <div class="relative p-10 md:p-16 rounded-3xl border-2 border-dashed border-primary-container bg-white/50">
      <form action="#" name="contact" data-netlify="true" class="flex flex-col gap-6 text-left" method="POST">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label class="font-label-caps text-on-surface-variant ml-1" for="name">NAME</label>
            <input class="w-full px-4 py-3 rounded-xl border-outline-variant bg-white focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" id="name" name="name" placeholder="Your Name" required type="text"/>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-caps text-on-surface-variant ml-1" for="email">EMAIL</label>
            <input class="w-full px-4 py-3 rounded-xl border-outline-variant bg-white focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none" id="email" name="email" placeholder="hello@example.com" required type="email"/>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <label class="font-label-caps text-on-surface-variant ml-1" for="message">MESSAGE</label>
          <textarea class="w-full px-4 py-3 rounded-xl border-outline-variant bg-white focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none min-h-[160px] resize-none" id="message" name="message" placeholder="What's on your mind?" required></textarea>
        </div>
        <button class="w-full md:w-fit md:px-12 py-4 bg-primary text-on-primary rounded-xl font-h3 transition-all hover:shadow-lg hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-2 self-center" type="submit">
          Send Message
          <span class="material-symbols-outlined text-sm">send</span>
        </button>
      </form>
    </div>
  </div>
</section>
