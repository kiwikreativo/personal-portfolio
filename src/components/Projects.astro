---
import ProjectCard from "./ProjectCard.astro";
import FloppyFishImage from "../assets/floppy-fish.webp";
import CirclesImage from "../assets/circles.webp";
import GithubIssuesImage from "../assets/github issues.webp";
import ChibiLuffyImage from "../assets/chibi-luffy.webp";
import FunctionalAdventureImage from "../assets/haskell-text-game.webp";

const projects = [
  {
    imageSrc: FloppyFishImage.src,
    imageAlt: "Floppy Fish",
    tag: "Java",
    title: "Floppy Fish",
    description: "Floppy fish is a spinoff Flappy bird, built in Java. Instead of gravity pulling the bird down, the buoyancy of the water pushes the fish up",
    link: "https://github.com/stephanieran/floppy-fish"
  },
  {
    imageSrc: CirclesImage.src,
    imageAlt: "Circles",
    tag: "Swift + Firebase",
    title: "Circles",
    description: "Circles is a photo sharing app with daily prompts to encourage small groups of families and friends to stay in touch.",
    link: "https://github.com/stephanieran/circles"
  },
  {
    imageSrc: GithubIssuesImage.src,
    imageAlt: "Github Issues",
    tag: "Swift + Github REST API",
    title: "Github Issues",
    description: "Github Issues is an iOS mobile application to streamline open/closed GitHub Issues posted in popular open-source repos for simple access.",
    link: "https://github.com/stephanieran/github-issues"
  },
  {
    imageSrc: ChibiLuffyImage.src,
    imageAlt: "Chibi Luffy",
    tag: "Swift + Github REST API",
    title: "Chibi Luffy",
    description: "Chibi Luffy is an Instagram bot that reposts anime memes scraped from Reddit.",
    link: "https://github.com/stephanieran/chibi-luffy"
  },
  {
    imageSrc: FunctionalAdventureImage.src,
    imageAlt: "Functional Adventure",
    tag: "Haskell",
    title: "Functional Adventure",
    description: "Functional adventure is a text-based adventure game with the goal of traversing the map to find a specific item.",
    link: "https://github.com/stephanieran/functional-adventure"
  },
];
---

<section class="py-[120px] bg-tertiary-container/10" id="projects">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16">
      <span class="font-label-caps text-label-caps text-primary mb-2 block tracking-widest">ENGINEERING SHOWCASE</span>
      <h2 class="font-display text-display text-on-surface">Software Engineering</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-grid-gutter">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </div>
</section>
