---
import SkillChip from "./SkillChip.astro";

const skills = [
  { icon: "code", label: "Python" },
  { icon: "terminal", label: "Java" },
  { icon: "smartphone", label: "Swift" },
  { icon: "palette", label: "Figma" },
  { icon: "database", label: "PostgreSQL" },
  { icon: "layers", label: "React" },
  { icon: "cloud_sync", label: "AWS" },
  { icon: "psychology", label: "User Testing" }
];
---

<section class="py-[120px] max-w-7xl mx-auto px-6 overflow-hidden" id="skills">
  <div class="flex flex-col items-center mb-16">
    <h2 class="font-display text-display text-on-surface mb-4">The Toolkit</h2>
    <div class="h-1 w-20 bg-primary-container rounded-full"></div>
  </div>
  <div class="flex flex-wrap justify-center gap-4">
    {skills.map(skill => (
      <SkillChip {...skill} />
    ))}
  </div>
</section>
